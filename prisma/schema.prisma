generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  id               String                  @id @default(cuid())
  userId           String?
  fullName         String
  headline         String?
  email            String
  phone            String
  address          String
  summary          String
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  socialLinks      SocialLink[]
  employment       EmploymentHistory[]
  education        EducationHistory[]
  skills           Skill[]
  tailoredVersions TailoredResumeVersion[]
  user             User?                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  passwordHash String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  profiles     Profile[]
  sessions     AuthSession[]
}

model AuthSession {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model SocialLink {
  id        String  @id @default(cuid())
  label     String
  url       String
  sortOrder Int
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model EmploymentHistory {
  id          String                @id @default(cuid())
  companyName String
  period      String
  title       String
  logoUrl     String?
  location    String?
  website     String?
  sortOrder   Int
  profileId   String
  profile     Profile               @relation(fields: [profileId], references: [id], onDelete: Cascade)
  workItems   EmploymentItem[]
  techStacks  EmploymentTechStack[]
}

model EmploymentItem {
  id           String            @id @default(cuid())
  content      String
  sortOrder    Int
  employmentId String
  employment   EmploymentHistory @relation(fields: [employmentId], references: [id], onDelete: Cascade)
}

model EmploymentTechStack {
  id           String            @id @default(cuid())
  name         String
  sortOrder    Int
  employmentId String
  employment   EmploymentHistory @relation(fields: [employmentId], references: [id], onDelete: Cascade)
}

model EducationHistory {
  id             String  @id @default(cuid())
  universityName String
  period         String
  degree         String
  summary        String?
  sortOrder      Int
  profileId      String
  profile        Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Skill {
  id        String  @id @default(cuid())
  name      String
  sortOrder Int
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model TailoredResumeVersion {
  id           String   @id @default(cuid())
  label        String?
  title        String?
  snapshotJson String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  profileId    String
  profile      Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model TailoringSettings {
  id                     String   @id @default("global")
  updateWorkItems        Boolean  @default(true)
  workItemUpdateMode     String   @default("replace")
  updateEmploymentTitles Boolean  @default(true)
  updateSkills           Boolean  @default(true)
  updateSummary          Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}
